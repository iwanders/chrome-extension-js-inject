{
  "name": "Minimal Javascript Inject",
  "version": "0.0.1",
  "manifest_version": 3,
  "description": "Injecting stuff", 
  "permissions":[
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background":{
    "service_worker": "background.js"
  },
  "action":{},
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "inject.js"
      ]
    },
    {
      "matches": [
        "https://www.google.com/"
      ],
      "js": [
        "specific_site.js"
      ],
      "run_at": "document_start"
    }
  ],
  "commands":{
    "foo":{
      "description": "foo on this string"
    }
  }
}